# SeatGeek Platform API — create an app at https://seatgeek.com/account/develop
SEATGEEK_CLIENT_ID=

# Ticketmaster Discovery API — get a key at https://developer.ticketmaster.com
TICKETMASTER_API_KEY=

# How often the background poller records a price snapshot for tracked matches
POLL_INTERVAL_MINUTES=30

# "Decent seat" estimate for Ticketmaster: min + DECENT_PERCENTILE * (max - min)
DECENT_PERCENTILE=0.35

# SQLite database location
DATABASE_PATH=./data/app.db

# Set to 1 to enable the /api/dev/snapshots test endpoint in production
DEV_TOOLS=
